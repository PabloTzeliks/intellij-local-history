<!--
    Plugin Configuration File.
    Documentação: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html

    Este é o arquivo central de registro do plugin. Aqui declaramos:
    - Metadados (id, nome, vendor)
    - Dependências da plataforma
    - Listeners (quem escuta eventos da IDE)
    - Extensions (tool windows, configuráveis, services)
-->
<idea-plugin>
    <!-- Identificador único do plugin no Marketplace -->
    <id>com.github.pablotzeliks.intellijlocalhistory</id>

    <!-- Nome exibido no Marketplace e em Settings > Plugins -->
    <name>Local History</name>

    <!-- Autor/organização -->
    <vendor>pablotzeliks</vendor>

    <!-- Descrição exibida na página do plugin -->
    <description><![CDATA[
        <p><b>Local History</b> automatically saves a copy of your files every time you save,
        keeping a local history of changes in a <code>.history</code> folder.</p>
        <p>Features:</p>
        <ul>
            <li>Automatic snapshots on every file save</li>
            <li>Visual diff comparison with current version</li>
            <li>One-click restore to any previous version</li>
            <li>Configurable retention policy</li>
            <li>Compatible with VS Code Local History extension</li>
        </ul>
    ]]></description>

    <!-- Dependência mínima: a plataforma base do IntelliJ -->
    <depends>com.intellij.modules.platform</depends>

    <!-- Bundle de strings para i18n -->
    <resource-bundle>messages.LocalHistoryBundle</resource-bundle>

    <!--
        applicationListeners: listeners que escutam eventos GLOBAIS da IDE.
        São instanciados de forma lazy (só quando o evento ocorre).
        Aqui registraremos o listener de save na Fase 1.
    -->
    <applicationListeners>
        <listener class="com.github.pablotzeliks.intellijlocalhistory.listener.DocumentSaveListener"
                  topic="com.intellij.openapi.fileEditor.FileDocumentManagerListener"/>
    </applicationListeners>

    <!--
        extensions: componentes que estendem a funcionalidade da IDE.
        Tool Windows, Configuráveis (Settings), etc.
        Serão adicionados nas Fases 2-5.
    -->
    <extensions defaultExtensionNs="com.intellij">
    </extensions>
</idea-plugin>
